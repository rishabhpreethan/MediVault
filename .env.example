# ─────────────────────────────────────────────
# MediVault — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────
POSTGRES_DB=medivault
POSTGRES_USER=medivault
POSTGRES_PASSWORD=change_me_postgres

# ── Redis ───────────────────────────────────
# (no extra config needed beyond URL below)

# ── MinIO ───────────────────────────────────
MINIO_ROOT_USER=medivault
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=medivault-documents

# ── Auth0 ───────────────────────────────────
# Get these from your Auth0 dashboard
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.medivault.local
AUTH0_CLIENT_ID=your_spa_client_id

# ── Encryption ──────────────────────────────
# AES-256 key for PHI field encryption (full_name, date_of_birth)
# Generate: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# ── Notifications (SMTP) ────────────────────
NOTIFICATIONS_ENABLED=false        # set to true to send emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                         # your sending email address
SMTP_PASSWORD=                     # Gmail App Password or account password
FROM_EMAIL=                        # defaults to SMTP_USER if blank

# ── App ─────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ─────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
# VITE_AUTH0_DOMAIN and VITE_AUTH0_CLIENT_ID and VITE_AUTH0_AUDIENCE
# are picked up from AUTH0_* above via docker-compose.yml
